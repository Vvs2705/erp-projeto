# ─── Variáveis de ambiente do backend ERP-V ───
# Em produção, defina via `flyctl secrets set` (NÃO commitar valores reais).

# Ambiente
ENV=production

# Banco (Neon). Use o driver asyncpg e SSL obrigatório.
# Converta a string do Neon trocando o esquema para postgresql+asyncpg e
# usando ?ssl=require (remova sslmode/channel_binding do Neon):
#   postgresql+asyncpg://USUARIO:SENHA@HOST/erp_v_db?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/erp_v?ssl=require

# JWT — gere um segredo forte (>=32 chars): `openssl rand -hex 32`
SECRET_KEY=troque-por-um-segredo-de-32-bytes-ou-mais

# CORS — domínio do frontend no Vercel (separe múltiplos por vírgula)
CORS_ORIGINS=https://seu-app.vercel.app

# Observabilidade (opcional)
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_ENABLED=false

# Fiscal — provedor DF-e (opcional; sem isto a emissão é recusada com erro claro)
# FISCAL_PROVIDER_URL=
# FISCAL_PROVIDER_TOKEN=
